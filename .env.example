# ===========================================
# AI Log Analyzer 环境变量配置
# ===========================================
# 复制此文件为 .env 并填写实际值：
#   cp .env.example .env

# ----- AI 模型配置 -----
# OpenAI 兼容 API（默认）
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=sk-xxx
AI_MODEL=gpt-4o

# Ollama 本地模型（可选）
# 取消注释并填写 Ollama 地址即可切换到本地模型
# AI_BASE_URL=http://host.docker.internal:11434/v1
# AI_API_KEY=
# AI_MODEL=qwen2.5

# ----- Ollama 配置 -----
# 用于获取本地模型列表
OLLAMA_BASE_URL=http://host.docker.internal:11434

# ----- 文件限制 -----
# 单文件最大大小（MB）
MAX_FILE_SIZE_MB=50

# ----- 上下文限制 -----
# 发送给 AI 的最大 token 数
MAX_CONTEXT_TOKENS=8000
