# ===========================================
# AI Log Analyzer 环境变量配置
# ===========================================
# 复制此文件为 .env 并填写实际值：
#   cp .env.example .env

# ----- AI 模型配置 -----
# OpenAI 兼容 API（默认）
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=sk-xxx
AI_MODEL=gpt-4o

# Ollama 本地模型（可选）
# 取消注释并填写 Ollama 地址即可切换到本地模型
# AI_BASE_URL=http://host.docker.internal:11434/v1
# AI_API_KEY=
# AI_MODEL=qwen2.5

# ----- Ollama 配置 -----
# 用于获取本地模型列表
OLLAMA_BASE_URL=http://host.docker.internal:11434

# ----- 文件限制 -----
# 单文件最大大小（MB）
MAX_FILE_SIZE_MB=50

# ----- 上下文限制 -----
# 发送给 AI 的最大 token 数
MAX_CONTEXT_TOKENS=8000

# ----- 知识库配置 -----
# 可选：连接 Obsidian 知识库，自动保存分析结果
#
# 方式 1：本地挂载（需在 docker-compose.yml 的 backend 服务 volumes 中自行挂载 Obsidian 路径）
# OBSIDIAN_LOCAL_PATH=/vault
#
# 方式 2：WebDAV 远程访问
# OBSIDIAN_WEBDAV_URL=http://your-nas:5005/Obsidian Vault
# OBSIDIAN_WEBDAV_USER=your-username
# OBSIDIAN_WEBDAV_PASS=your-password

# ----- 限流器配置 -----
# 限流器后端：sqlite 支持多容器复本共享，memory 仅适合单进程
RATE_LIMITER_BACKEND=sqlite

# ----- 日志脱敏 -----
# 上传日志时在入库前自动脱敏（IPv4/手机号/邮箱/JWT/Bearer token/API key/身份证号），
# 替换为 [IP_1]、[PHONE_1] 等占位符，避免公司敏感数据随日志内容发送给外部 LLM API。
# 占位符 -> 原始值 的映射按文件保存在数据库 log_files.masking_map，供将来还原。
# 默认 true（开启）；设为 false 关闭。
# MASK_SENSITIVE_DATA=true

# ----- CORS 配置 -----
# 允许访问后端的前端来源，多个用英文逗号分隔
# 默认为 * 允许任何来源（开发使用），生产环境建议改为具体域名
# ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# ----- 反向代理 / 真实客户端 IP（限流准确性）-----
# 反向代理后端时，仅当直连 peer IP 在此白名单（逗号分隔，精确 IP 匹配）才信任
# X-Forwarded-For / X-Real-IP，否则回退到直连 IP（代理后限流可能失效）。
# 示例（Docker 网关 / 本机）：TRUSTED_PROXIES=127.0.0.1,172.18.0.1
# TRUSTED_PROXIES=

# ----- Cookie 安全（JWT httpOnly cookie）-----
# 登录 token 通过 httpOnly cookie 下发。生产环境（HTTPS）必须设为 true，
# 本地 http 开发保持 false（否则浏览器不会回传 Secure cookie）。
# COOKIE_SECURE=false

# ----- Grafana 配置 -----
# 监控面板管理员密码
GRAFANA_ADMIN_PASSWORD=admin

# ----- JWT 安全密钥（必填）-----
# 启动时强制校验：必须设置 >=32 字节的随机密钥，否则应用拒绝启动。
# 生成方式：python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=

# ----- 首次管理员账号（已废弃）-----
# 首次安装请通过登录页创建管理员账号
# DEFAULT_ADMIN_USERNAME=admin
# DEFAULT_ADMIN_PASSWORD=your-admin-password
