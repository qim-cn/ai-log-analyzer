# ===========================================
# AI Log Analyzer 环境变量配置
# ===========================================
# 复制此文件为 .env 并填写实际值：
#   cp .env.example .env

# ----- AI 模型配置 -----
# OpenAI 兼容 API（默认）
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=sk-xxx
AI_MODEL=gpt-4o

# Ollama 本地模型（可选）
# 取消注释并填写 Ollama 地址即可切换到本地模型
# AI_BASE_URL=http://host.docker.internal:11434/v1
# AI_API_KEY=
# AI_MODEL=qwen2.5

# ----- Ollama 配置 -----
# 用于获取本地模型列表
OLLAMA_BASE_URL=http://host.docker.internal:11434

# ----- 文件限制 -----
# 单文件最大大小（MB）
MAX_FILE_SIZE_MB=50

# ----- 上下文限制 -----
# 发送给 AI 的最大 token 数
MAX_CONTEXT_TOKENS=8000

# ----- 知识库配置 -----
# 连接 Obsidian Vault，自动保存分析结果
#
# 方式 1：本地挂载（推荐）
#   在 docker-compose.yml 中取消注释 vault 卷挂载，容器内路径为 /vault
OBSIDIAN_LOCAL_PATH=/vault
#   vault 内目标路径（相对于 vault 根目录），默认 /03-AI分析/incidents/
OBSIDIAN_VAULT_PATH=/03-AI分析/incidents/
#
# 方式 2：WebDAV 远程访问（NAS 场景）
# OBSIDIAN_WEBDAV_URL=http://192.168.31.5:5005/Obsidian Vault/服务器维修笔记
# OBSIDIAN_WEBDAV_USER=your-username
# OBSIDIAN_WEBDAV_PASS=your-password
# OBSIDIAN_VAULT_PATH=/03-AI分析/incidents/

# ----- 限流器配置 -----
# 限流器后端：sqlite 支持多容器复本共享，memory 仅适合单进程
RATE_LIMITER_BACKEND=sqlite

# ----- CORS 配置 -----
# 允许访问后端的前端来源，多个用英文逗号分隔
# 默认为 * 允许任何来源（开发使用），生产环境建议改为具体域名
# ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# ----- Grafana 配置 -----
# 监控面板管理员密码
GRAFANA_ADMIN_PASSWORD=admin

# ----- JWT 安全密钥 -----
# 生产环境务必修改！
# JWT_SECRET=your-random-secret-key

# ----- 首次管理员账号（已废弃）-----
# 首次安装请通过登录页创建管理员账号
# DEFAULT_ADMIN_USERNAME=admin
# DEFAULT_ADMIN_PASSWORD=your-admin-password
